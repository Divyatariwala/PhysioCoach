{
  "version": 2,
  "builds": [
    {
      "src": "theratrack-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "theratrack-frontend/build" }
    },
    {
      "src": "theratrack/theratrack/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "theratrack/theratrack/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "theratrack-frontend/build/index.html"
    }
  ]
}